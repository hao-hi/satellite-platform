{
  "schema_version": 1,
  "metadata": {
    "name": "quick_pd_zero",
    "description": "Short PD closed-loop smoke scenario with zero environment.",
    "tags": ["platform", "pd", "zero-environment"]
  },
  "time": {
    "duration_s": 2.0,
    "dt_s": 0.02,
    "seed": 3
  },
  "system": {
    "builder": "default",
    "controller": "pd",
    "identify_inertia": false,
    "environment": "zero"
  },
  "controller": {
    "pd_kp": 1.5,
    "pd_kd": 0.35
  },
  "sensors": {
    "attitude": {
      "noise_std_rad": 0.0006
    },
    "gyro": {
      "noise_std_rad_s": 0.001,
      "bias_std_rad_s": 0.002,
      "bias_rw_scale": 0.02
    }
  },
  "initial_state": {
    "use_default": true
  },
  "acceptance": {
    "max_final_error_deg": 40.0,
    "max_rms_error_deg": 40.0,
    "max_peak_torque_nm": 0.2
  },
  "outputs": {
    "root": "results/platform/quick_pd_zero",
    "save_manifest_json": true,
    "save_metrics_csv": true,
    "save_time_history_csv": true,
    "save_events_csv": true,
    "save_markdown_report": true
  }
}
