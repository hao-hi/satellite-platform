    "template": "single_mode",
    "mode": "inertial_hold",
    "reference": "body_zero"
  },
  "outputs": {
    "root": "results/platform_library/cubesat_rw_fault_seed_mc"
  },
  "acceptance": {
    "max_final_error_deg": 60.0,
    "max_rms_error_deg": 60.0,
    "max_peak_torque_nm": 0.08
  }
}
