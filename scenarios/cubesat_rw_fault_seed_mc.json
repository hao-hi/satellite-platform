{
  "schema_version": 1,
  "metadata": {
    "name": "cubesat_rw_fault_seed_mc",
    "description": "Curated Monte Carlo robustness experiment for the reaction-wheel fault scenario.",
    "tags": ["platform", "library", "monte_carlo", "fault", "robustness"]
  },
  "scenario": "cubesat_rw_fault.json",
  "monte_carlo": {
    "samples": 8,
    "seed": 20
  },
  "runtime": {
