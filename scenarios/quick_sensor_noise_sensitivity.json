{
  "schema_version": 1,
  "metadata": {
    "name": "quick_sensor_noise_sensitivity",
    "description": "Curated sensor-quality sensitivity experiment for the quick PD baseline scenario.",
    "tags": ["platform", "library", "sensor_sensitivity", "gyro_noise"]
  },
  "scenario": "quick_pd_zero.json",
  "sweeps": [
    {
      "path": "sensors.gyro.noise_std_rad_s",
      "values": [0.0005, 0.001, 0.002, 0.004]
    }
  ],
  "runtime": {
    "template": "single_rate"
  },
  "mission": {
    "template": "single_mode",
    "mode": "inertial_hold",
    "reference": "body_zero"
  },
  "outputs": {
    "root": "results/platform_library/quick_sensor_noise_sensitivity"
  },
  "acceptance": {
    "max_final_error_deg": 40.0,
    "max_rms_error_deg": 40.0,
    "max_peak_torque_nm": 0.2
  }
}
