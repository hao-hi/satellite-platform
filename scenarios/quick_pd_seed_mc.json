{
  "schema_version": 1,
  "metadata": {
    "name": "quick_pd_seed_mc",
    "description": "Curated Monte Carlo robustness experiment for the quick PD baseline scenario.",
    "tags": ["platform", "library", "monte_carlo", "robustness"]
  },
  "scenario": "quick_pd_zero.json",
  "monte_carlo": {
    "samples": 8,
    "seed": 10
  },
  "runtime": {
    "template": "single_rate"
  },
  "mission": {
    "template": "single_mode",
    "mode": "inertial_hold",
    "reference": "body_zero"
  },
  "outputs": {
    "root": "results/platform_library/quick_pd_seed_mc"
  },
  "acceptance": {
    "max_final_error_deg": 45.0,
    "max_rms_error_deg": 45.0,
    "max_peak_torque_nm": 0.2
  }
}
