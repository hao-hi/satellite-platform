  },
  "outputs": {
    "root": "results/platform_library/cubesat_rw_earth_transition_curated"
  },
  "acceptance": {
    "max_final_error_deg": 60.0,
    "max_rms_error_deg": 60.0,
    "max_peak_torque_nm": 0.05
  }
}
